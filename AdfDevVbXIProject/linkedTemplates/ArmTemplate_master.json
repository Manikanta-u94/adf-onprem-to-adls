{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "AdfDevVbXIProject"
		},
		"LS_Adls_SQL_parquet_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_Adls_SQL_parquet'"
		},
		"LS_ONPREM_SQLServer_DW_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_ONPREM_SQLServer_DW'"
		},
		"LS_Parent_Sqlserver_DW_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_Parent_Sqlserver_DW'"
		},
		"LS_Adls_SQL_parquet_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevvbxiproject.dfs.core.windows.net"
		},
		"LS_ONPREM_SQLServer_DW_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "LAPTOP-MUDU581E\\SQLEXPRESS"
		},
		"LS_ONPREM_SQLServer_DW_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "RetailDW_Dev"
		},
		"LS_ONPREM_SQLServer_DW_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "mani"
		},
		"LS_Parent_Sqlserver_DW_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "LAPTOP-MUDU581E\\SQLEXPRESS"
		},
		"LS_Parent_Sqlserver_DW_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "RetailDW_Dev"
		},
		"LS_Parent_Sqlserver_DW_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "mani"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "AdfDevVbXIProject_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_Adls_SQL_parquet_accountKey": {
						"value": "[parameters('LS_Adls_SQL_parquet_accountKey')]"
					},
					"LS_ONPREM_SQLServer_DW_password": {
						"value": "[parameters('LS_ONPREM_SQLServer_DW_password')]"
					},
					"LS_Parent_Sqlserver_DW_password": {
						"value": "[parameters('LS_Parent_Sqlserver_DW_password')]"
					},
					"LS_Adls_SQL_parquet_properties_typeProperties_url": {
						"value": "[parameters('LS_Adls_SQL_parquet_properties_typeProperties_url')]"
					},
					"LS_ONPREM_SQLServer_DW_properties_typeProperties_server": {
						"value": "[parameters('LS_ONPREM_SQLServer_DW_properties_typeProperties_server')]"
					},
					"LS_ONPREM_SQLServer_DW_properties_typeProperties_database": {
						"value": "[parameters('LS_ONPREM_SQLServer_DW_properties_typeProperties_database')]"
					},
					"LS_ONPREM_SQLServer_DW_properties_typeProperties_userName": {
						"value": "[parameters('LS_ONPREM_SQLServer_DW_properties_typeProperties_userName')]"
					},
					"LS_Parent_Sqlserver_DW_properties_typeProperties_server": {
						"value": "[parameters('LS_Parent_Sqlserver_DW_properties_typeProperties_server')]"
					},
					"LS_Parent_Sqlserver_DW_properties_typeProperties_database": {
						"value": "[parameters('LS_Parent_Sqlserver_DW_properties_typeProperties_database')]"
					},
					"LS_Parent_Sqlserver_DW_properties_typeProperties_userName": {
						"value": "[parameters('LS_Parent_Sqlserver_DW_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}